---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Results from '../components/Results.astro';
import Cases from '../components/Cases.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Markus Kollers — Produkt & Engineering"
  lang="de"
  description="Markus Kollers: Produkt und Engineering in einer Person. Ich baue digitale Produkte vom Konzept bis in den laufenden Betrieb."
>
  <Header lang="de" />
  <main>
    <Hero lang="de" />
    <Results lang="de" />
    <Cases lang="de" />
    <Contact lang="de" />
  </main>
  <Footer lang="de" />
</BaseLayout>
