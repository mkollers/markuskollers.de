---
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const cases = (await getCollection('projects', (p) => p.data.lang === lang)).sort((a, b) => a.data.order - b.data.order);
---

<section id="projekte" class="scroll-mt-20 mx-auto max-w-5xl px-6 pb-16 md:pb-24">
  <div class="mb-8 flex items-center gap-3">
    <span class="h-px w-8 bg-accent"></span>
    <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent-text">{t('cases.label')}</span>
  </div>

  <div class="flex flex-col gap-5">
    {
      cases.map((c) => (
        <article class="rounded-xl border border-border bg-white/50 p-6 md:p-8">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-xs text-muted">
                <span>{c.data.role}</span>
                <span aria-hidden="true" class="text-border">
                  ·
                </span>
                <span>{c.data.timeframe}</span>
                {c.data.status && <span class="rounded-full bg-accent-soft px-2 py-0.5 text-accent-text">{c.data.status}</span>}
              </div>

              <h3 class="mt-3 font-display text-2xl font-medium text-ink">{c.data.title}</h3>
              <p class="mt-1 leading-relaxed text-muted">{c.data.tagline}</p>
              {c.data.partner && (
                <p class="mt-2 font-mono text-xs text-muted">
                  {t('cases.partner')}{' '}
                  <a href={c.data.partner.url} target="_blank" rel="noopener noreferrer" class="text-accent-text hover:underline">
                    {c.data.partner.name}
                  </a>
                </p>
              )}
            </div>
            {c.data.logo && (
              <img
                src={c.data.logo}
                alt=""
                loading="lazy"
                class="mt-1 h-6 w-auto max-w-[38%] shrink-0 object-contain object-right md:h-7"
              />
            )}
          </div>

          <dl class="mt-6 grid gap-5 sm:grid-cols-3">
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-accent-text">{t('cases.problem')}</dt>
              <dd class="mt-2 text-sm leading-relaxed text-muted">{c.data.problem}</dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-accent-text">{t('cases.solution')}</dt>
              <dd class="mt-2 text-sm leading-relaxed text-muted">{c.data.solution}</dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-accent-text">{t('cases.result')}</dt>
              <dd class="mt-2 text-sm leading-relaxed text-ink">{c.data.result}</dd>
            </div>
          </dl>

          {(c.data.stack.length > 0 || c.data.url) && (
            <div class="mt-6 flex flex-wrap items-center gap-2 border-t border-border pt-5">
              {c.data.stack.map((s) => (
                <span class="rounded-md border border-border px-2 py-1 font-mono text-xs text-muted">{s}</span>
              ))}
              {c.data.url && (
                <a
                  href={c.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="ml-auto inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-wider text-accent-text hover:underline"
                >
                  {t('cases.live')}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="size-3.5"
                    aria-hidden="true"
                  >
                    <path d="M7 17 17 7" />
                    <path d="M8 7h9v9" />
                  </svg>
                </a>
              )}
            </div>
          )}
        </article>
      ))
    }
  </div>
</section>
